<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/incoming_bg">

    <LinearLayout
        android:id="@+id/card"
        android:layout_width="330dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp"
        android:background="@drawable/glass_card"
        android:elevation="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ✅ Step 1: Ignore Button (Close/Cross) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageButton
                android:id="@+id/btnIgnore"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="2dp"
                android:background="@android:color/transparent"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="#FFFFFF"
                android:contentDescription="Ignore Call"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/logoText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="G9Expert"
            android:textStyle="bold"
            android:textSize="24sp"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/avatarText"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:text="KC"
            android:textStyle="bold"
            android:textSize="34sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/avatar_circle"/>

        <TextView
            android:id="@+id/callerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Kapil Chilhate"
            android:textStyle="bold"
            android:textSize="26sp"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/callerSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Customer Calling"
            android:textColor="#D5D9E8"
            android:textSize="16sp"
            android:layout_marginTop="6dp"/>

        <TextView
            android:id="@+id/callType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Incoming Audio Consultation"
            android:textColor="#8CCFFF"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginTop="18dp"/>
            <!-- ✅ Step 2: Timer hidden - Production UI -->
<TextView
    android:id="@+id/countdownText"
    android:layout_width="0dp"
    android:layout_height="0dp"
    android:visibility="gone"/>
        

        <LinearLayout
            android:id="@+id/actionContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- Reject -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/btnReject"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/reject_button"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#FFFFFF"
                    android:padding="18dp"
                    android:contentDescription="Reject Call"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Decline"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

            <!-- Accept -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageButton
                    android:id="@+id/btnAccept"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/accept_button"
                    android:src="@android:drawable/sym_action_call"
                    android:tint="#FFFFFF"
                    android:padding="18dp"
                    android:contentDescription="Accept Call"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accept"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="10dp"/>

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/securityText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒 End-to-End Encrypted"
            android:textColor="#B8C7D9"
            android:textSize="13sp"
            android:layout_marginTop="30dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>